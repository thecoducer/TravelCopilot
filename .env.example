# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=info

# ── LLM ──────────────────────────────────────────────────────────────────────
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
OPENAI_API_KEY=sk-...

# ── Mock flag (set true during dev to avoid real API calls) ──────────────────
MOCK_EXTERNAL_APIS=true

# ── External Search APIs ─────────────────────────────────────────────────────
SERPAPI_KEY=
TAVILY_API_KEY=

# ── Maps & Places ─────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_API_KEY=

# ── Weather ───────────────────────────────────────────────────────────────────
OPENWEATHERMAP_API_KEY=

# ── Currency Exchange ─────────────────────────────────────────────────────────
FX_API_KEY=

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/travelcopilot

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Langfuse (self-hosted local) ──────────────────────────────────────────────
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=travelcopilot-backend

# ── Clarification gate ────────────────────────────────────────────────────────
CLARIFICATION_REQUIRED_FIELDS=destination,dates,travelers
PARSE_CONFIDENCE_THRESHOLD=0.6

# ── Budget guard ──────────────────────────────────────────────────────────────
MAX_LLM_SPEND_USD_PER_TRIP=1.00
